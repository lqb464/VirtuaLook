# VirtuaLook — environment template
# Copy to services/vton/.env and edit as needed.

# ── Backend selection ─────────────────────────────────────────────────────────
# auto     = Replicate (if token set) → CatVTON (if weights) → mock
# replicate | catvton | mock
VTON_BACKEND=catvton

# Force mock overlay (skip all real inference) — good for UI/API dev
MOCK_MODE=false

# ── Device ────────────────────────────────────────────────────────────────────
# auto | cuda | cpu
DEVICE=auto

# ── Storage ───────────────────────────────────────────────────────────────────
# Relative to services/vton/ unless absolute path
UPLOAD_DIR=../../storage

# ── CatVTON local weights ─────────────────────────────────────────────────────
CATVTON_DIR=./weights/catvton
CATVTON_CHECKPOINT=vitonhd-16k-512
SD_INPAINT_DIR=./weights/sd-inpaint

# ── Inference tuning ──────────────────────────────────────────────────────────
INFERENCE_STEPS=20
INFERENCE_WIDTH=512
INFERENCE_HEIGHT=768

# ── Replicate cloud (IDM-VTON) ────────────────────────────────────────────────
# Get token: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# REPLICATE_MODEL=cuuupid/idm-vton:d73e611d73581af0410fc0b5cc400e2cae959a92cb6c8b54d6ad102c52b4d5ab

# ── HuggingFace (faster downloads, higher rate limits) ───────────────────────
# Get token: https://huggingface.co/settings/tokens
HF_TOKEN=

HOST=127.0.0.1
PORT=8000
